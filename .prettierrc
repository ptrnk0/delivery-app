{
  "trailingComma": "none",
  "useTabs": false,
  "semi": false,
  "tabWidth": 2,
  "jsxSingleQuote": true,
  "singleQuote": true,
  "arrowParens": "avoid",
  "importOrder": [
    "<THIRD_PARTY_MODULES>",
    "",
    "^@/navigation/(.*)$",
    "",
    "^@/components/(.*)$",
    "",
    "^@/hooks/(.*)$",
    "",
    "^@/types/(.*)$",
    "",
    "^@/services/(.*)$",
    "",
    "^@/assets/(.*)$",
    "",
    "^@/utils/(.*)$",
    "",
    "^[./]"
  ],
  "importOrderCaseSensitive": false,
  "plugins": ["@ianvs/prettier-plugin-sort-imports"]
}
